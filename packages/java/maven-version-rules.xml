<?xml version="1.0" encoding="UTF-8"?>
<ruleset comparisonMethod="maven"
         xmlns="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0 https://www.mojohaus.org/versions/versions-maven-plugin/xsd/rule-2.0.0.xsd">
    <rules>
        <!-- Exclude pre-release versions globally -->
        <rule groupId="*" artifactId="*">
            <ignoreVersions>
                <ignoreVersion type="regex">.*[-.](?i)(alpha|beta|rc|cr|m|milestone|preview|snapshot|ea|incubating)[-.]?.*</ignoreVersion>
            </ignoreVersions>
        </rule>
    </rules>
</ruleset>
