		},
		{
			"type": "count_min",
			"field": "structure",
			"value": 1
		},
		{
			"type": "contains",
			"field": "structure_kinds",
			"value": "Function"
		},
		{
			"type": "count_min",
			"field": "imports",
			"value": 1
		},
		{
			"type": "greater_than_or_equal",
			"field": "metrics.total_lines",
			"value": 7
		},
		{
			"type": "equals",
			"field": "metrics.error_count",
			"value": 0
		}
	]
}
