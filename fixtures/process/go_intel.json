{
	"id": "go_function_process",
	"description": "Intel: extract structure from Go function definition",
	"category": "process",
	"tags": ["intel"],
	"skip": {
		"reason": "Requires go language"
	},
	"input": {
		"language": "go",
		"source_code": "package main\n\nimport \"fmt\"\n\nfunc main() {\n\tfmt.Println(\"hello\")\n}\n"
	},
	"assertions": [
		{
			"type": "equals",
