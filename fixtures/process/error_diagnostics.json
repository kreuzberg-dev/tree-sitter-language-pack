{
	"id": "python_error_diagnostics",
	"description": "Intel: Python code with syntax errors should report diagnostics",
	"category": "process",
	"tags": ["intel", "error", "diagnostics"],
	"skip": {
		"reason": "Requires python language"
	},
	"input": {
		"source_code": "def broken(\n    pass\n",
		"config": {
			"language": "python"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "language",
			"value": "python"
		},
		{
			"type": "equals",
			"field": "metrics.error_count",
			"value": 1
		},
		{
			"type": "not_empty",
			"field": "diagnostics"
		}
	]
}
