{
	"id": "rust_chunking_process_detail",
	"description": "Intel: chunk multi-function Rust source into pieces",
	"category": "process",
	"tags": ["metadata", "chunking"],
	"skip": {
		"reason": "Requires rust language"
	},
	"input": {
		"language": "rust",
		"source_code": "fn alpha() {}\n\nfn beta() {}\n\nfn gamma() {}\n\nfn delta() {}\n"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "language",
			"value": "rust"
		},
		{
			"type": "greater_than_or_equal",
			"field": "metrics.total_lines",
			"value": 7
		},
		{
			"type": "count_min",
			"field": "chunks",
			"value": 2
		},
		{
			"type": "less_than_or_equal",
			"field": "max_chunk_size",
			"value": 30
		}
	]
}
