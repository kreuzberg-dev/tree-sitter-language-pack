{
	"id": "extract_patterns_python_functions",
	"description": "Extract function definitions from Python source using tree-sitter query",
	"category": "extraction",
	"tags": ["extraction", "patterns"],
	"call": "extract",
	"input": {
		"source_code": "def hello():\n    pass\n\ndef world(x):\n    return x * 2\n",
		"config": {
			"language": "python",
			"patterns": {
				"functions": {
					"query": "(function_definition name: (identifier) @name)",
					"capture_output": "Full"
				}
			}
		}
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "equals",
			"field": "language",
			"value": "python"
		},
		{
			"type": "count_min",
			"field": "results.functions.matches",
			"value": 2
		}
	],
	"skip": {
		"languages": ["rust"],
		"reason": "Rust e2e generator does not yet support this pattern"
	}
}
