					"byte_range": [9999, 99999]
				}
			}
		}
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "count_equals",
			"field": "results.funcs.matches",
			"value": 0
		}
	],
	"skip": {
		"languages": ["rust"],
		"reason": "Opaque return type not supported in Rust e2e"
	}
}
