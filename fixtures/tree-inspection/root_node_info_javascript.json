{
	"id": "tree_root_node_info_javascript",
	"description": "Parse JavaScript source and verify root node type is program",
	"category": "tree-inspection",
	"tags": ["tree-inspection"],
	"call": "parse",
	"input": {
		"language": "javascript",
		"source_code": "const x = 1;\n"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "method_result",
			"method": "root_node_type",
			"check": "equals",
			"value": "program"
		}
	]
}
