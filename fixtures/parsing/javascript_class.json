{
	"id": "parsing_javascript_class",
	"description": "Parse a JavaScript class declaration.",
	"category": "parsing",
	"tags": ["parsing"],
	"call": "parse",
	"input": {
		"language": "javascript",
		"source_code": "class Foo { bar() {} }"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "greater_than_or_equal",
			"field": "root_child_count",
			"value": 1
		},
		{
			"type": "method_result",
			"method": "contains_node_type",
			"args": {
				"node_type": "class_declaration"
			},
			"check": "is_true"
		}
	]
}
