{
	"id": "parsing_html_element",
	"description": "Parse an HTML element and assert node type",
	"category": "parsing",
	"tags": ["parsing", "html"],
	"call": "parse",
	"input": {
		"language": "html",
		"source_code": "<div>hello</div>"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "method_result",
			"method": "contains_node_type",
			"args": {
				"node_type": "element"
			},
			"check": "is_true"
		}
	]
}
