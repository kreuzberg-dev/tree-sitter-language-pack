{
	"id": "smoke_zsh",
	"description": "Smoke test: load zsh and parse a simple snippet",
	"category": "smoke",
	"tags": ["smoke"],
	"call": "parse",
	"input": {
		"language": "zsh",
		"source_code": "echo hello"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "method_result",
			"method": "root_child_count",
			"check": "greater_than_or_equal",
			"value": 1
		}
	]
}
