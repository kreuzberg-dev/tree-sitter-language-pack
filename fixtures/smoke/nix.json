{
	"id": "smoke_nix",
	"description": "Smoke test: load nix and parse a simple snippet",
	"category": "smoke",
	"tags": ["smoke"],
	"call": "parse",
	"input": {
		"language": "nix",
		"source_code": "{ pkgs ? import <nixpkgs> {} }: pkgs.hello"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "greater_than_or_equal",
			"field": "root_child_count",
			"value": 1
		}
	]
}
