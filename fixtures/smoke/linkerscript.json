{
	"id": "smoke_linkerscript",
	"description": "Smoke test: load linkerscript and parse a simple snippet",
	"category": "smoke",
	"tags": ["smoke"],
	"call": "parse",
	"input": {
		"language": "linkerscript",
		"source_code": "SECTIONS { .text : { *(.text) } }"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "greater_than_or_equal",
			"field": "root_child_count",
			"value": 1
		}
	]
}
