{
  "name": "@tree-sitter-language-pack/node",
  "version": "2.0.0-alpha.1",
  "description": "Tree-sitter language pack - pre-compiled parsers for 170+ languages (Node.js NAPI bindings)",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "napi": {
    "name": "ts-pack-node",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "x86_64-pc-windows-msvc",
        "aarch64-pc-windows-msvc"
      ]
    }
  },
  "engines": {
    "node": ">= 16"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Goldziher/tree-sitter-language-pack"
  },
  "keywords": [
    "tree-sitter",
    "parser",
    "syntax",
    "napi",
    "language-pack"
  ],
  "license": "MIT OR Apache-2.0"
}
